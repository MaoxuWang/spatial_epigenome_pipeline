# Copy this file to config/pipeline.env and edit paths for your cluster.
# Keep machine-specific paths out of committed pipeline scripts.

# Repository-local script and resource directories.
SPATIAL_EPIGENOME_SCRIPT_DIR="${SPATIAL_EPIGENOME_REPO_ROOT}/scripts"
SPATIAL_EPIGENOME_RESOURCE_DIR="${SPATIAL_EPIGENOME_REPO_ROOT}/resources"

# Command paths. Use executable names when tools are available in PATH.
CUTADAPT="cutadapt"
TRIM_GALORE="trim_galore"
BEDTOOLS="bedtools"
BOWTIE2="bowtie2"
SAMTOOLS="samtools"
UMI_TOOLS="umi_tools"
SEQKIT="seqkit"
PYTHON="python"
PYTHON_CV2="python"
RSCRIPT="Rscript"
PICARD="picard"
MACS2="macs2"
BAMCOVERAGE="bamCoverage"
BIGWIG_TO_BEDGRAPH="bigWigToBedGraph"
BEDGRAPH_TO_BIGWIG="bedGraphToBigWig"
FASTQC="fastqc"
SPACERANGER="spaceranger"
STAR="STAR"

# External research tools that are not shipped with this repository.
SPATIAL_IVT="spatial_IVT"
SPATIAL_LIANTI="spatial_lianti"
MERGE_SUPER_SPOT="levelMatrix.py"
ZUMIS="bash /path/to/zUMIs.sh"
SEEKSPACE_TOOLS="seekspacetools"
BBMAP_BBDUK="bbduk.sh"
CELLRANGER_ATAC="cellranger-atac"

# Reference indexes and annotations.
HG38_BOWTIE2_INDEX="/path/to/bowtie2/hg38"
MM10_BOWTIE2_INDEX="/path/to/bowtie2/mm10"
HG38_STAR_INDEX="/path/to/star/hg38"
MM10_STAR_INDEX="/path/to/star/mm10"
HG38_CHROM_SIZES="/path/to/hg38.chrom.sizes"
MM10_CHROM_SIZES="/path/to/mm10.chrom.sizes"
HG38_GTF="/path/to/hg38/genes.gtf"
MM10_GTF="/path/to/mm10/genes.gtf"
HG38_GFF3="/path/to/gencode.hg38.annotation.gff3"
MM10_GFF3="/path/to/gencode.mm10.annotation.gff3"
HG38_CELLRANGER_ARC_REF="/path/to/refdata-cellranger-arc-GRCh38"
MM10_CELLRANGER_ARC_REF="/path/to/refdata-cellranger-arc-mm10"
HG38_10X_GEX_REF="/path/to/refdata-gex-GRCh38"
MM10_10X_GEX_REF="/path/to/refdata-gex-mm10"
HG38_BISMARK_INDEX="/path/to/Bismark_hg38"
MM10_BISMARK_INDEX="/path/to/Bismark_mm10"

# QC masks and genome metadata.
HG38_AUTOSOME_BED="/path/to/hg38.autosome.txt"
MM10_AUTOSOME_BED="/path/to/mm10.autosome.txt"
HG38_RMSK_BED="/path/to/hg38.rmsk.bed"
MM10_RMSK_BED="/path/to/mm10.rmsk.bed"

# BST/ROI tools used by the LIANTI-style pipeline.
BST_SRC_S1000="/path/to/BSTMatrix_v2.3.r"
BST_SRC_S3000="/path/to/BSTMatrix_v2.4_adapted"

# Optional script/module paths used by helper scripts.
MM10_BLACKLIST_BED="/path/to/ENCODE.mm10.blacklist.bed"
HG38_BLACKLIST_BED="/path/to/ENCODE.hg38.blacklist.bed"
METASEQ_PATH="/path/to/metaseq"
DSCHIC_R_FUNCTION_DIR="/path/to/dscHi-C/scripts"
REMOVE_SPOT_SWAP="${SPATIAL_EPIGENOME_REPO_ROOT}/tools/remove_spot_swap.sh"
